---
import type { Timeline } from '../../data/types';

interface Props {
  timeline: Timeline;
}

const { timeline } = Astro.props;
---

{(timeline.stats.keyOutcomes || timeline.stats.achievements || timeline.stats.humanitarianImpacts) && (
  <div class="mb-12 space-y-8">
    <h2 class="text-3xl font-bold text-center timeline-primary mb-8">Key Outcomes & Impact</h2>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-8">
      <!-- Key Outcomes -->
      {timeline.stats.keyOutcomes && timeline.stats.keyOutcomes.length > 0 && (
        <div class="bg-gradient-to-br from-blue-900/30 to-black border border-blue-500/30 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 bg-blue-500/20 border border-blue-500/50 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-blue-300">Key Outcomes</h3>
          </div>
          <div class="space-y-4">
            {timeline.stats.keyOutcomes.map((outcome, index) => (
              <div class="flex items-start gap-3 p-3 bg-blue-500/5 border border-blue-500/20 rounded-lg">
                <div class="w-6 h-6 bg-blue-500/20 rounded-full flex items-center justify-center text-xs text-blue-300 font-bold mt-0.5 flex-shrink-0">
                  {index + 1}
                </div>
                <p class="text-gray-300 leading-relaxed">{outcome}</p>
              </div>
            ))}
          </div>
        </div>
      )}
      
      <!-- Achievements -->
      {timeline.stats.achievements && timeline.stats.achievements.length > 0 && (
        <div class="bg-gradient-to-br from-green-900/30 to-black border border-green-500/30 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 bg-green-500/20 border border-green-500/50 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-green-300">Notable Achievements</h3>
          </div>
          <div class="space-y-4">
            {timeline.stats.achievements.map((achievement, index) => (
              <div class="flex items-start gap-3 p-3 bg-green-500/5 border border-green-500/20 rounded-lg">
                <div class="w-6 h-6 bg-green-500/20 rounded-full flex items-center justify-center text-xs text-green-300 font-bold mt-0.5 flex-shrink-0">
                  ✓
                </div>
                <p class="text-gray-300 leading-relaxed">{achievement}</p>
              </div>
            ))}
          </div>
        </div>
      )}
      
      <!-- Humanitarian Impacts -->
      {timeline.stats.humanitarianImpacts && timeline.stats.humanitarianImpacts.length > 0 && (
        <div class="bg-gradient-to-br from-red-900/30 to-black border border-red-500/30 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 bg-red-500/20 border border-red-500/50 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-red-300">Humanitarian Impact</h3>
          </div>
          <div class="space-y-4">
            {timeline.stats.humanitarianImpacts.map((impact, index) => (
              <div class="flex items-start gap-3 p-3 bg-red-500/5 border border-red-500/20 rounded-lg">
                <div class="w-6 h-6 bg-red-500/20 rounded-full flex items-center justify-center text-xs text-red-300 font-bold mt-0.5 flex-shrink-0">
                  !
                </div>
                <p class="text-gray-300 leading-relaxed">{impact}</p>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
    
    <!-- Timeline Summary -->
    <div class="bg-gradient-to-br from-gray-900 to-black border timeline-border rounded-xl p-8 text-center">
      <h3 class="text-2xl font-bold timeline-primary mb-4">Timeline Summary</h3>
      <p class="text-gray-300 leading-relaxed max-w-4xl mx-auto text-lg">
        {timeline.description}
      </p>
      {timeline.context && (
        <p class="text-gray-400 leading-relaxed max-w-3xl mx-auto text-base mt-4">
          {timeline.context}
        </p>
      )}
      <div class="mt-6 flex items-center justify-center gap-4 text-sm text-gray-500">
        <span>Period: {new Date(timeline.startTimestamp * 1000).getFullYear()}{timeline.endTimestamp ? ` - ${new Date(timeline.endTimestamp * 1000).getFullYear()}` : ' - Present'}</span>
        <span>•</span>
        <span>{timeline.stats.totalEvents} documented events</span>
        <span>•</span>
        <span class={`font-semibold ${
          timeline.status === 'ongoing' ? 'text-red-400' :
          timeline.status === 'historical' ? 'text-blue-400' :
          'text-gray-400'
        }`}>
          {timeline.status.toUpperCase()}
        </span>
      </div>
    </div>
  </div>
)} 