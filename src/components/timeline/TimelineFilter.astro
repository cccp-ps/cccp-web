---
import type { Timeline, EventCategory, SignificanceLevel, SourceType } from '../../data/types';

interface Props {
  timeline: Timeline;
}

const { timeline } = Astro.props;

// Extract available filter options from timeline data
const availableCategories: EventCategory[] = [...new Set(timeline.events.map(event => event.category))];
const availableSignificance: SignificanceLevel[] = [...new Set(timeline.events.map(event => event.significance))];
const availableSourceTypes: SourceType[] = [...new Set(timeline.events.flatMap(event => event.sources.map(source => source.type)))];
---

<div class="mb-8 bg-gradient-to-br from-gray-900 to-black border timeline-border rounded-xl">
  <!-- Toggle Header -->
  <div class="flex items-center justify-between p-6 cursor-pointer" id="filter-toggle">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-purple-500/20 border border-purple-500/50 rounded-lg flex items-center justify-center">
        <svg class="w-4 h-4 text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
        </svg>
      </div>
      <h3 class="text-xl font-bold timeline-primary">Filter Events</h3>
      <div class="flex items-center gap-2 text-sm text-gray-400">
        <span id="filter-count">{timeline.stats.totalEvents} events</span>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <span id="filter-status" class="text-sm text-gray-500">Click to expand</span>
      <svg id="filter-chevron" class="w-5 h-5 text-gray-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
  </div>
  
  <!-- Collapsible Content -->
  <div id="filter-content" class="hidden border-t border-gray-700">
    <div class="p-6">
      <div class="flex items-center justify-between mb-6">
        <div class="text-lg font-semibold text-gray-300">Filter Options</div>
        <button 
          id="clear-filters" 
          class="px-4 py-2 bg-gray-700/50 border border-gray-600 rounded-lg text-sm text-gray-300 hover:text-white hover:bg-gray-600/50 transition-colors duration-200"
        >
          Clear All
        </button>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Category Filter -->
        <div>
          <label class="block text-sm font-medium text-gray-400 mb-3">Categories</label>
          <div class="space-y-2 max-h-40 overflow-y-auto">
            {availableCategories.map((category) => (
              <label class="flex items-center gap-2 cursor-pointer">
                <input 
                  type="checkbox" 
                  class="category-filter rounded border-gray-600 bg-gray-800 text-blue-500 focus:ring-blue-500 focus:ring-2"
                  value={category}
                  checked
                />
                <span class="text-sm text-gray-300 capitalize">{category.replace('_', ' ')}</span>
              </label>
            ))}
          </div>
        </div>
        
        <!-- Significance Filter -->
        <div>
          <label class="block text-sm font-medium text-gray-400 mb-3">Significance</label>
          <div class="space-y-2">
            {availableSignificance.map((significance) => (
              <label class="flex items-center gap-2 cursor-pointer">
                <input 
                  type="checkbox" 
                  class="significance-filter rounded border-gray-600 bg-gray-800 text-blue-500 focus:ring-blue-500 focus:ring-2"
                  value={significance}
                  checked
                />
                <span class={`text-sm capitalize font-medium ${
                  significance === 'critical' ? 'text-red-300' :
                  significance === 'major' ? 'text-orange-300' :
                  significance === 'moderate' ? 'text-yellow-300' :
                  'text-gray-300'
                }`}>
                  {significance}
                </span>
              </label>
            ))}
          </div>
        </div>
        
        <!-- Source Types Filter -->
        <div>
          <label class="block text-sm font-medium text-gray-400 mb-3">Source Types</label>
          <div class="space-y-2 max-h-40 overflow-y-auto">
            {availableSourceTypes.map((sourceType) => (
              <label class="flex items-center gap-2 cursor-pointer">
                <input 
                  type="checkbox" 
                  class="source-filter rounded border-gray-600 bg-gray-800 text-blue-500 focus:ring-blue-500 focus:ring-2"
                  value={sourceType}
                  checked
                />
                <span class="text-sm text-gray-300 capitalize">{sourceType.replace('_', ' ')}</span>
              </label>
            ))}
          </div>
        </div>
        
        <!-- Date Range Filter -->
        <div>
          <label class="block text-sm font-medium text-gray-400 mb-3">Date Range</label>
          <div class="space-y-3">
            <div>
              <label class="block text-xs text-gray-500 mb-1">From</label>
              <input 
                type="date" 
                id="date-from"
                class="w-full px-3 py-2 bg-gray-800 border border-gray-600 rounded-lg text-sm text-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                value={new Date(timeline.startTimestamp * 1000).toISOString().split('T')[0]}
              />
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">To</label>
              <input 
                type="date" 
                id="date-to"
                class="w-full px-3 py-2 bg-gray-800 border border-gray-600 rounded-lg text-sm text-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                value={timeline.endTimestamp ? 
                  new Date(timeline.endTimestamp * 1000).toISOString().split('T')[0] :
                  new Date().toISOString().split('T')[0]
                }
              />
            </div>
          </div>
        </div>
      </div>
      
      <!-- Active Filters Display -->
      <div class="mt-6 pt-4 border-t border-gray-700">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm text-gray-400">Active Filters:</span>
          <span id="event-count" class="text-sm timeline-primary font-semibold">
            {timeline.stats.totalEvents} events
          </span>
        </div>
        <div id="active-filters" class="flex flex-wrap gap-2">
          <!-- Active filter tags will be populated by JavaScript -->
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Toggle functionality
    const filterToggle = document.getElementById('filter-toggle');
    const filterContent = document.getElementById('filter-content');
    const filterChevron = document.getElementById('filter-chevron');
    const filterStatus = document.getElementById('filter-status');
    
    // Filter functionality elements
    const categoryFilters = document.querySelectorAll('.category-filter');
    const significanceFilters = document.querySelectorAll('.significance-filter');
    const sourceFilters = document.querySelectorAll('.source-filter');
    const dateFromInput = document.getElementById('date-from') as HTMLInputElement;
    const dateToInput = document.getElementById('date-to') as HTMLInputElement;
    const clearFiltersBtn = document.getElementById('clear-filters');
    const eventCountDisplay = document.getElementById('event-count');
    const activeFiltersDisplay = document.getElementById('active-filters');
    
    let isExpanded = false;
    
    // Toggle filter panel
    function toggleFilterPanel() {
      isExpanded = !isExpanded;
      
      if (isExpanded) {
        filterContent?.classList.remove('hidden');
        if (filterChevron) filterChevron.style.transform = 'rotate(180deg)';
        if (filterStatus) filterStatus.textContent = 'Click to collapse';
      } else {
        filterContent?.classList.add('hidden');
        if (filterChevron) filterChevron.style.transform = 'rotate(0deg)';
        if (filterStatus) filterStatus.textContent = 'Click to expand';
      }
    }
    
    // Add toggle event listener
    if (filterToggle) {
      filterToggle.addEventListener('click', toggleFilterPanel);
    }
    
    // Apply filters to events
    function applyFilters() {
      const selectedCategories = Array.from(categoryFilters)
        .filter(cb => (cb as HTMLInputElement).checked)
        .map(cb => (cb as HTMLInputElement).value);
        
      const selectedSignificance = Array.from(significanceFilters)
        .filter(cb => (cb as HTMLInputElement).checked)
        .map(cb => (cb as HTMLInputElement).value);
        
      const selectedSources = Array.from(sourceFilters)
        .filter(cb => (cb as HTMLInputElement).checked)
        .map(cb => (cb as HTMLInputElement).value);
        
      const dateFrom = dateFromInput ? new Date(dateFromInput.value).getTime() / 1000 : 0;
      const dateTo = dateToInput ? new Date(dateToInput.value).getTime() / 1000 : Infinity;
      
      // Hide/show event cards based on filters
      const eventCards = document.querySelectorAll('[data-event-id]');
      let visibleCount = 0;
      
      eventCards.forEach(card => {
        const eventElement = card as HTMLElement;
        const eventCategory = eventElement.dataset.eventCategory;
        const eventSignificance = eventElement.dataset.eventSignificance;
        const eventTimestamp = parseInt(eventElement.dataset.eventTimestamp || '0');
        const eventSources = (eventElement.dataset.eventSources || '').split(',');
        
        const categoryMatch = selectedCategories.includes(eventCategory || '');
        const significanceMatch = selectedSignificance.includes(eventSignificance || '');
        const sourceMatch = eventSources.some(source => selectedSources.includes(source));
        const dateMatch = eventTimestamp >= dateFrom && eventTimestamp <= dateTo;
        
        const isVisible = categoryMatch && significanceMatch && sourceMatch && dateMatch;
        
        if (isVisible) {
          eventElement.style.display = 'block';
          visibleCount++;
        } else {
          eventElement.style.display = 'none';
        }
      });
      
      // Update event count
      if (eventCountDisplay) {
        eventCountDisplay.textContent = `${visibleCount} events`;
      }
      
      // Update active filters display
      updateActiveFiltersDisplay(selectedCategories, selectedSignificance, selectedSources, dateFrom, dateTo);
    }
    
    // Update active filters display
    function updateActiveFiltersDisplay(categories: string[], significance: string[], sources: string[], dateFrom: number, dateTo: number) {
      if (!activeFiltersDisplay) return;
      
      const filterTags: string[] = [];
      
      if (categories.length > 0) {
        filterTags.push(`Categories: ${categories.join(', ')}`);
      }
      if (significance.length > 0) {
        filterTags.push(`Significance: ${significance.join(', ')}`);
      }
      if (sources.length > 0) {
        filterTags.push(`Sources: ${sources.slice(0, 3).join(', ')}${sources.length > 3 ? '...' : ''}`);
      }
      if (dateFrom > 0 || dateTo < Infinity) {
        filterTags.push('Date range applied');
      }
      
      if (filterTags.length === 0) {
        activeFiltersDisplay.innerHTML = '<span class="text-gray-500 text-sm">All events visible</span>';
      } else {
        activeFiltersDisplay.innerHTML = filterTags.map(tag => 
          `<span class="px-2 py-1 bg-blue-500/20 border border-blue-500/30 rounded text-xs text-blue-300">${tag}</span>`
        ).join('');
      }
    }
    
    // Clear all filters
    function clearAllFilters() {
      categoryFilters.forEach(cb => (cb as HTMLInputElement).checked = true);
      significanceFilters.forEach(cb => (cb as HTMLInputElement).checked = true);
      sourceFilters.forEach(cb => (cb as HTMLInputElement).checked = true);
      
      if (dateFromInput) dateFromInput.value = dateFromInput.defaultValue;
      if (dateToInput) dateToInput.value = dateToInput.defaultValue;
      
      applyFilters();
    }
    
    // Add event listeners
    categoryFilters.forEach(filter => filter.addEventListener('change', applyFilters));
    significanceFilters.forEach(filter => filter.addEventListener('change', applyFilters));
    sourceFilters.forEach(filter => filter.addEventListener('change', applyFilters));
    
    if (dateFromInput) dateFromInput.addEventListener('change', applyFilters);
    if (dateToInput) dateToInput.addEventListener('change', applyFilters);
    if (clearFiltersBtn) clearFiltersBtn.addEventListener('click', clearAllFilters);
    
    // Initial filter application
    applyFilters();
  });
</script> 