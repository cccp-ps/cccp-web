---
// Humanitarian organizations data
const organizations = [
  {
    id: 'pcrf',
    name: 'Palestine Children\'s Relief Fund',
    icon: '🏥',
    description: 'Providing medical care and humanitarian relief to children throughout the Levant.',
    url: 'https://www.pcrf.net/',
    theme: 'red'
  },
  {
    id: 'prcs',
    name: 'Palestine Red Crescent Society',
    icon: '🚑',
    description: 'Emergency medical services, disaster management, and humanitarian aid throughout Palestine.',
    url: 'https://www.palestinercs.org/en',
    theme: 'green'
  },
  {
    id: 'unrwa',
    name: 'UNRWA',
    icon: '🏠',
    description: 'UN agency providing education, healthcare, and emergency aid to Palestinian refugees.',
    url: 'https://donate.unrwa.org/int/en/general',
    theme: 'blue'
  }
];
---

<section class="mt-16 pt-16 border-t border-gray-800">
  <!-- Humanitarian Organizations Support -->
  <div class="bg-gradient-to-br from-green-900/20 to-green-800/10 border border-green-500/30 rounded-2xl p-8 mb-12">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 leading-tight">
        🤝 Support Palestinian Humanitarian Organizations
      </h2>
      <p class="text-xl text-gray-300 leading-relaxed max-w-4xl mx-auto">
        Please consider donating directly to organizations providing critical humanitarian aid to Palestinians in need.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {organizations.map((org) => (
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-br from-green-500/10 to-green-600/5 rounded-xl blur-sm opacity-50 group-hover:opacity-75 transition-opacity duration-300"></div>
          <div class="relative bg-gradient-to-br from-gray-900/90 to-black/90 border border-green-500/30 rounded-xl p-6 backdrop-blur-sm shadow-xl group-hover:border-green-400/50 transition-all duration-300 h-full flex flex-col">
            <div class="text-center flex-1">
              <div class="text-4xl mb-4">{org.icon}</div>
              <h3 class="text-xl font-bold text-white mb-4 leading-tight">{org.name}</h3>
              <p class="text-gray-300 text-sm leading-relaxed mb-6 flex-1">{org.description}</p>
              <a 
                href={org.url} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="inline-flex items-center gap-2 bg-green-600/80 hover:bg-green-600 text-white font-semibold px-6 py-3 rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl group-hover:scale-105"
              >
                <span>Donate to {org.id.toUpperCase()}</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Solidarity Message -->
  <div class="bg-gradient-to-r from-red-900/30 via-black/50 to-green-900/30 border border-white/20 rounded-2xl p-8 mb-12">
    <div class="text-center">
      <div class="text-5xl mb-6">🇵🇸</div>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 leading-tight">
        From the River to the Sea, Palestine Will Be Free
      </h2>
      <p class="text-xl text-gray-300 mb-8 max-w-4xl mx-auto leading-relaxed">
        In solidarity with the Palestinian people facing systematic oppression and violence. We stand for justice, human dignity, and the right to exist.
      </p>
      <div class="w-full max-w-2xl mx-auto h-6 bg-gradient-to-r from-red-600 via-white to-green-600 rounded-full shadow-lg"></div>
    </div>
  </div>

  <!-- Site Support -->
  <div class="text-center">
    <button 
      id="toggleSiteSupport" 
      class="text-gray-500 hover:text-gray-400 text-sm underline transition-colors duration-200 mb-4"
    >
      Help cover website development & hosting costs
    </button>
    
    <div id="siteSupportSection" class="hidden">
      <div class="flex justify-center">
        <div class="relative group max-w-sm">
          <div class="absolute inset-0 bg-gradient-to-r from-white/10 to-white/5 rounded-xl blur-sm opacity-50 group-hover:opacity-75 transition-opacity duration-300"></div>
          <div class="relative bg-gradient-to-br from-gray-900/90 to-black/90 border border-white/20 rounded-xl p-6 backdrop-blur-sm shadow-xl">
            <div class="text-center mb-4">
              <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-5 py-2.5 mb-3">
                <span class="text-lg">⚙️</span>
                <span class="text-white font-medium text-base tracking-wide">Site Development</span>
              </div>
              <p class="text-gray-400 text-xs mb-1">For website development & hosting costs only</p>
              <p class="text-gray-500 text-xs">Please prioritize the humanitarian organizations above</p>
            </div>
            
            <div class="flex justify-center">
              <iframe 
                src="https://trocador.app/anonpay/?ticker_to=xmr&network_to=Mainnet&address=86Mt3EAG12gHteUHmqz3eZdtAWB6MQNrS1U3er4DNhddcSTjiHPU8fCNJx94T9P3yvf92QcU6TCweCh9T2KHiVcjHeX2mmh&donation=True&simple_mode=True&name=CCCP.PS&description=Donation+for+CCCP.PS&email=web@cccp.ps&bgcolor=" 
                width="300" 
                height="300" 
                style="border:0; border-radius: px; overflow:hidden;" 
                title="Cryptocurrency Donation"
                loading="lazy"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleButton = document.getElementById('toggleSiteSupport');
    const supportSection = document.getElementById('siteSupportSection');
    
    if (toggleButton && supportSection) {
      toggleButton.addEventListener('click', () => {
        const isHidden = supportSection.classList.contains('hidden');
        
        if (isHidden) {
          supportSection.classList.remove('hidden');
          toggleButton.textContent = 'Hide site support options';
        } else {
          supportSection.classList.add('hidden');
          toggleButton.textContent = 'Help cover website development & hosting costs';
        }
      });
    }
  });
</script> 