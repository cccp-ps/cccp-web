---
// biome-ignore lint/correctness/noUnusedImports: used in Astro template below
import LivePreview from "../components/LivePreview.astro";
// biome-ignore lint/correctness/noUnusedImports: used in Astro template below
import Layout from "../layouts/Layout.astro";
---

<Layout title="CCCP.PS — Status">
	<img src="/cccp-logo.svg" alt="CCCP.PS logo" class="hero-logo" />
	<h1 class="hero-title">CCCP.PS</h1>

	<div class="content-container">
		<div class="status-box">
					<div class="status">
						<span class="status-dot status-dot--live"></span>
						<span class="status-text">INVITES DISPATCHED</span>
					</div>

					<div class="dispatch-card" role="status" aria-label="Invitation status">
						<div class="dispatch-header">
							<h2 class="dispatch-title">YOU'RE IN</h2>
							<p class="dispatch-subtitle">After 29 days of maintenance, all invitations have been sent out.</p>
						</div>

						<div class="dispatch-items" role="list">
							<div class="dispatch-item" role="listitem">
								<div class="dispatch-icon-wrap dispatch-icon-wrap--success" aria-hidden="true">
									<svg class="dispatch-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
								</div>
								<div class="dispatch-item-content">
									<span class="dispatch-item-label">Discord</span>
									<span class="dispatch-item-desc">Invite has been posted to the server</span>
								</div>
							</div>
							<div class="dispatch-item" role="listitem">
								<div class="dispatch-icon-wrap dispatch-icon-wrap--success" aria-hidden="true">
									<svg class="dispatch-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22 4 12 13 2 4"/></svg>
								</div>
								<div class="dispatch-item-content">
									<span class="dispatch-item-label">Email</span>
									<span class="dispatch-item-desc">Invitation sent to all registered addresses</span>
								</div>
							</div>
							<div class="dispatch-item dispatch-item--note" role="listitem">
								<div class="dispatch-icon-wrap dispatch-icon-wrap--warn" aria-hidden="true">
									<svg class="dispatch-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
								</div>
								<div class="dispatch-item-content">
									<span class="dispatch-item-label">Can't find it?</span>
									<span class="dispatch-item-desc">Check your spam or junk folder</span>
								</div>
							</div>
						</div>
					</div>

					<LivePreview />

					<hr class="section-divider" aria-hidden="true" />

					<div class="comms-box">
						<p class="comms-desc">Join the community for real-time updates and discussions.</p>
						<div class="discord-links">
							<a href="https://discord.com/channels/333693176944525324/772394563792666673/1466005774315819204" target="_blank" rel="noopener noreferrer" class="discord-btn">
								<svg class="discord-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
								View Announcement
							</a>
							<a href="https://discord.com/channels/333693176944525324/772394563792666673" target="_blank" rel="noopener noreferrer" class="discord-btn">
								<svg class="discord-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
								#plex-news
							</a>
						</div>
					</div>
				</div>
	</div>
</Layout>

<style>
	/* Hero */
	.hero-logo {
		width: clamp(60px, 10vw, 90px);
		height: auto;
		margin-bottom: 1rem;
		animation: float 6s ease-in-out infinite;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-3px); }
	}

	.hero-title {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(2rem, 5vw, 3rem);
		letter-spacing: 0.25em;
		font-weight: 400;
		color: #e8e6e3;
		margin-bottom: 3rem;
	}

	/* Content */
	.content-container {
		width: 100%;
		max-width: 600px;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.section-divider {
		border: none;
		border-top: 1px solid #1a1a1d;
		width: 100%;
		margin: 1rem 0 2rem 0;
	}

	/* Status Box */
	.status-box {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	/* Status indicator */
	.status {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 2rem;
		background: #111113;
		padding: 0.5rem 1.25rem;
		border-radius: 999px;
		border: 1px solid #1a1a1d;
	}

	.status-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: #c9434d;
		flex-shrink: 0;
		animation: pulse-dot 2s ease-in-out infinite;
	}

	.status-dot--live {
		background: #22c55e;
		box-shadow: 0 0 8px rgba(34, 197, 94, 0.4);
	}

	@keyframes pulse-dot {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.3; }
	}

	.status-text {
		font-size: 0.7rem;
		letter-spacing: 0.15em;
		color: #7a7880;
		font-weight: 500;
	}

	/* Dispatch Card */
	.dispatch-card {
		width: 100%;
		max-width: 480px;
		background: #111113;
		border: 1px solid #1a1a1d;
		border-radius: 8px;
		overflow: hidden;
		margin-bottom: 2rem;
		animation: card-in 0.6s ease-out both;
		animation-delay: 0.2s;
	}

	@keyframes card-in {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.dispatch-header {
		padding: 1.75rem 1.75rem 1.25rem;
		border-bottom: 1px solid #1a1a1d;
		background: linear-gradient(135deg, rgba(201, 67, 77, 0.06) 0%, transparent 60%);
	}

	.dispatch-title {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(1.8rem, 5vw, 2.4rem);
		letter-spacing: 0.15em;
		font-weight: 400;
		color: #e8e6e3;
		line-height: 1;
		margin-bottom: 0.75rem;
	}

	.dispatch-subtitle {
		font-size: 0.8rem;
		line-height: 1.6;
		color: #7a7880;
	}

	.dispatch-items {
		display: flex;
		flex-direction: column;
	}

	.dispatch-item {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1.1rem 1.75rem;
		border-bottom: 1px solid #1a1a1d;
		transition: background 0.2s ease;
	}

	.dispatch-item:last-child {
		border-bottom: none;
	}

	.dispatch-item:hover {
		background: rgba(255, 255, 255, 0.015);
	}

	.dispatch-icon-wrap {
		width: 32px;
		height: 32px;
		border-radius: 6px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.dispatch-icon-wrap--success {
		background: rgba(34, 197, 94, 0.1);
		color: #22c55e;
	}

	.dispatch-icon-wrap--warn {
		background: rgba(234, 179, 8, 0.1);
		color: #eab308;
	}

	.dispatch-icon {
		width: 16px;
		height: 16px;
	}

	.dispatch-item-content {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.dispatch-item-label {
		font-size: 0.85rem;
		color: #e8e6e3;
		font-weight: 500;
		letter-spacing: 0.02em;
	}

	.dispatch-item-desc {
		font-size: 0.75rem;
		color: #4a484f;
		letter-spacing: 0.01em;
	}

	/* Comms Box */
	.comms-box {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 2rem 0;
	}

	.comms-desc {
		font-size: 0.9rem;
		color: #7a7880;
		margin-bottom: 2rem;
		text-align: center;
	}

	/* Discord links */
	.discord-links {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
		width: 100%;
		max-width: 300px;
	}

	.discord-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.8rem 1.5rem;
		border-radius: 4px;
		border: 1px solid #1a1a1d;
		background: #111113;
		color: #e8e6e3;
		text-decoration: none;
		font-size: 0.9rem;
		font-family: 'JetBrains Mono', monospace;
		transition: all 0.2s ease;
		width: 100%;
		justify-content: center;
	}

	.discord-btn:hover {
		border-color: #5865F2; /* Discord color */
		box-shadow: 0 0 16px rgba(88, 101, 242, 0.15);
		transform: translateY(-1px);
	}

	.discord-icon {
		width: 20px;
		height: 20px;
		flex-shrink: 0;
	}

	/* Reduced motion */
	@media (prefers-reduced-motion: reduce) {
		.hero-logo { animation: none; }
		.status-dot { animation: none; }
		.dispatch-card { animation: none; }
	}
</style>

